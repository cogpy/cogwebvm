# cogpy Organization — Standardized Git Attributes
# KSM Evolution Cycle 13: Technology Infrastructure Standardization
#
# POLICY:
# - Only truly large ML model files (>50MB) are tracked via LFS
# - Small media files (images, docs, audio <50MB) are committed directly
# - This prevents LFS object availability issues from blocking CI/CD
#
# To enable LFS for this repo: git lfs install && git lfs pull

# AI/ML Model Files (large, should use LFS)
*.bin filter=lfs diff=lfs merge=lfs -text
*.safetensors filter=lfs diff=lfs merge=lfs -text
*.gguf filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text

# Linguist overrides for cognitive architecture repos
*.py linguist-language=Python
*.jl linguist-language=Julia
*.scm linguist-language=Scheme
*.dis linguist-language=Limbo
*.b linguist-language=Limbo
*.m linguist-language=Limbo

# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare text files
*.md text
*.txt text
*.yml text
*.yaml text
*.json text
*.toml text
*.cfg text
*.ini text
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.jl text eol=lf
*.scm text eol=lf
*.c text
*.h text
*.cpp text
*.hpp text

# Declare binary files (committed directly, NOT via LFS)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.mp4 binary
*.mp3 binary
*.ogg binary
*.wav binary
*.zip binary
*.tar.gz binary
*.woff2 binary
